# ============================================
# Job Application Platform — Environment Variables
# ============================================
# Copy this file to .env.local (Next.js) and python-service/.env (Python)
# NEVER commit actual secrets to git.

# ── Supabase (Auth + Database) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
DATABASE_URL=postgresql://postgres.xxx:password@pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ── Application ──
ENCRYPTION_SECRET=change-me-to-a-random-32-byte-hex-string

# ── LLM APIs (server-side only) ──
OPENAI_API_KEY=sk-your_openai_key_here

GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

DEEPSEEK_API_KEY=sk-your_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Python Scraper Service ──
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_API_KEY=dev-service-key

# ── Firecrawl (for Wellfound scraping) ──
FIRECRAWL_API_KEY=fc-your_key_here

# ── Outreach Safety ──
DEFAULT_DRY_RUN=true
MAX_EMAILS_PER_DAY=10

# ── Global SMTP (for Free tier users) ──
GLOBAL_SMTP_HOST=smtp.gmail.com
GLOBAL_SMTP_PORT=587
GLOBAL_SMTP_USER=your-global-smtp@gmail.com
GLOBAL_SMTP_PASS=your-gmail-app-password

# ── Removed (no longer used) ──
# NEXTAUTH_SECRET → replaced by Supabase
# NEXTAUTH_URL → replaced by Supabase
# GOOGLE_CLIENT_ID → configured directly in Supabase dashboard
# GOOGLE_CLIENT_SECRET → configured directly in Supabase dashboard
